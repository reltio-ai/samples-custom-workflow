  <process id="dcrAddS3Attribute" name="DCR Review Add Attribute" isExecutable="true">
    <startEvent id="startevent1" name="Start">
      <extensionElements>
        <activiti:executionListener class="com.reltio.workflow.activiti.service.DCRHasChangesListener" event="start" />
      </extensionElements>
    </startEvent>
    <sequenceFlow id="flow1" sourceRef="startevent1" targetRef="dcrReview" />
    <userTask id="dcrReview" name="DCR Review" activiti:candidateGroups="ROLE_REVIEWER" activiti:dueDate="P2D">
      <extensionElements>
        <activiti:formProperty id="decision" name="Decision" type="enum" required="true" default="Approve">
          <activiti:value id="Approve" name="Approve" />
          <activiti:value id="Reject" name="Reject" />
        </activiti:formProperty>
        <activiti:formProperty id="validator" name="Validator" type="string" writable="false" default="com.reltio.workflow.core.task.validator.DataChangeRequestValidator" />
        <activiti:formProperty id="notificationOnAssignmentEnabled" name="NotificationOnAssignmentEnabled" type="boolean" writable="false" default="true" />
        <activiti:formProperty id="notificationOnCompletionEnabled" name="NotificationOnCompletionEnabled" type="boolean" writable="false" default="true" />
        <activiti:taskListener class="com.reltio.workflow.activiti.service.TaskStartEventListener" event="create" />
        <activiti:taskListener class="com.reltio.workflow.activiti.service.DCRTypeTaskListener" event="create" />
        <activiti:taskListener class="com.reltio.workflow.activiti.service.TaskAssignmentEventListener" event="assignment" />
      </extensionElements>
    </userTask>
    <sequenceFlow id="flow2" sourceRef="dcrReview" targetRef="exclusivegateway1" />
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway" />
    <sequenceFlow id="Approve" name="Approve" sourceRef="exclusivegateway1" targetRef="ApproveService">
      <conditionExpression xsi:type="tFormalExpression">${decision=='Approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Reject" name="Reject" sourceRef="exclusivegateway1" targetRef="RejectService">
      <conditionExpression xsi:type="tFormalExpression">${decision=='Reject'}</conditionExpression>
    </sequenceFlow>
    <serviceTask id="ApproveService" name="Approve and Add Attribute Service" activiti:class="com.reltio.workflow.sample.aws.ApplyDCRAddFromS3" />
    <sequenceFlow id="flow5" sourceRef="ApproveService" targetRef="endevent1" />
    <serviceTask id="RejectService" name="Reject Service" activiti:class="com.reltio.workflow.activiti.service.ChangeRequestReject" />
    <sequenceFlow id="flow6" sourceRef="RejectService" targetRef="endevent1" />
    <endEvent id="endevent1" name="End" />
    <dataObject id="manualStart" name="manualStart" itemSubjectRef="xsd:boolean">
      <extensionElements>
        <activiti:value>false</activiti:value>
      </extensionElements>
    </dataObject>
    <dataObject id="deleted" name="deleted" itemSubjectRef="xsd:boolean">
      <extensionElements>
        <activiti:value>false</activiti:value>
      </extensionElements>
    </dataObject>
    <association id="Association_0a623rb" sourceRef="ApproveService" targetRef="TextAnnotation_0gt3rk2" />
    <textAnnotation id="TextAnnotation_0gt3rk2">
      <text>This service adds new attributes defined in S3 to the new entities after the DCR approval</text>
    </textAnnotation>
  </process>
