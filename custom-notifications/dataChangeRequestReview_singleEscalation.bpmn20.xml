    <sequenceFlow id="SequenceFlow_1dqoz9h" sourceRef="dcrReview" targetRef="exclusivegateway1" />
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>SequenceFlow_1dqoz9h</incoming>
      <outgoing>Approve</outgoing>
      <outgoing>Reject</outgoing>
